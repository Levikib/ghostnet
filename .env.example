# GHOSTNET Environment Configuration
# Copy this file to .env.local and fill in your values

# ─────────────────────────────────────────────
# AI AGENT — GHOST (Required for chat agent)
# ─────────────────────────────────────────────

# Groq API (FREE — 14,400 req/day)
# Get key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Alternative: Anthropic Claude (paid)
# Get key: https://console.anthropic.com
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ─────────────────────────────────────────────
# OPTIONAL ENHANCEMENTS
# ─────────────────────────────────────────────

# Shodan API (for enhanced tool reference)
# Get key: https://account.shodan.io
# SHODAN_API_KEY=your_shodan_key_here

# HaveIBeenPwned API (for breach intel)
# Get key: https://haveibeenpwned.com/API/Key
# HIBP_API_KEY=your_hibp_key_here
