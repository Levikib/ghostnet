# ═══════════════════════════════════════════════════════════════════
# GHOSTNET — Environment Configuration Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# AI AGENT — GHOST (Required for Ghost Agent chat)
# ─────────────────────────────────────────────────────────────────
# Groq — FREE tier: 14,400 req/day, llama-3.3-70b-versatile, 4096 tokens
# Get your free API key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─────────────────────────────────────────────────────────────────
# SUPABASE — Auth + Database (Required for user accounts + leaderboard)
# ─────────────────────────────────────────────────────────────────
# 1. Create a free project at https://supabase.com
# 2. Settings → API → copy Project URL and anon/public key
# 3. Run supabase-schema.sql in your project's SQL Editor to create all tables
# 4. Auth → URL Configuration → set:
#      Site URL:        https://your-domain.com
#      Redirect URLs:   https://your-domain.com/api/auth/callback
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─────────────────────────────────────────────────────────────────
# ADMIN PANEL (Required to access the admin tab on /leaderboard)
# ─────────────────────────────────────────────────────────────────
# Comma-separated list of email addresses that get admin access.
# These users see the admin tab with full user list, emails, lab history.
#
# SECURITY: Use ADMIN_EMAILS (server-only, never exposed to the browser).
# The old NEXT_PUBLIC_ADMIN_EMAIL is kept for backwards compatibility only.
ADMIN_EMAILS=you@yourdomain.com

# ─────────────────────────────────────────────────────────────────
# OPTIONAL INTEGRATIONS
# ─────────────────────────────────────────────────────────────────
# Shodan API key — enhances the Shodan query builder tool
# Get free key: https://account.shodan.io
# SHODAN_API_KEY=your_shodan_key

# HaveIBeenPwned API key — for breach lookup features
# HIBP_API_KEY=your_hibp_key
