# ═══════════════════════════════════════════════════════════════════
# GHOSTNET — Environment Configuration Template
# Copy to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# AI AGENT — GHOST (Required)
# ─────────────────────────────────────────────────────────────────
# Groq — FREE tier: 14,400 req/day, llama-3.3-70b-versatile
# Get key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─────────────────────────────────────────────────────────────────
# SUPABASE — Auth + Database (Required for user features)
# ─────────────────────────────────────────────────────────────────
# 1. Create project at https://supabase.com (free tier)
# 2. Settings → API → copy Project URL and anon key
# 3. Run supabase-schema.sql in your Supabase SQL Editor
# 4. Auth → URL Configuration:
#      Site URL: https://ghostnet-pi.vercel.app
#      Redirect: https://ghostnet-pi.vercel.app/api/auth/callback
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─────────────────────────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────────────────────────
# SHODAN_API_KEY=your_shodan_key
# HIBP_API_KEY=your_hibp_key
